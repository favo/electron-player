{
  "name": "pintomind-player",
  "version": "0.1.0",
  "description": "Player app for PinToMind",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "electron-builder --linux snap",
    "dist:linux": "electron-builder --linux",
    "publish": "electron-builder --linux -p always"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favo/electron-player.git"
  },
  "author": "Favo AS",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/favo/electron-player/issues"
  },
  "homepage": "https://github.com/favo/electron-player#readme",
  "devDependencies": {
    "electron": "^22.0.0",
    "electron-builder": "^22.10.3"
  },
  "dependencies": {
    "bleno": "npm:@abandonware/bleno@^0.5.1-4",
    "electron-shutdown-command": "^2.0.1",
    "qrcode": "^1.5.1",
    "systeminformation": "^5.12.3"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "favo",
        "repo": "electron-player"
      }
    ],
    "appId": "no.favo.pintomindplayer",
    "productName": "PintomindPlayer",
    "linux": {
      "target": {
        "target": "AppImage",
        "arch": [
          "armv7l"
        ]
      },
      "maintainer": "Favo AS",
      "category": "Utility",
      "artifactName": "pintomindplayer.AppImage"
    }
  }
}
